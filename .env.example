# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

# App
APP_NAME=API
# Set DEBUG=true for colored human-readable logs, and DEBUG=false for JSON structured logs in Production.
DEBUG=true
API_PREFIX=/api

# Sentry
SENTRY_DSN=
SENTRY_ARQ_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.005

# Telegram bot for ElevenLabs vs current Whisper comparison
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
ELEVENLABS_API_KEY=
WHISPER_SERVER_URL=http://10.0.10.3:8000/transcribe
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_DIARIZE=true
ELEVENLABS_TAG_AUDIO_EVENTS=true
ELEVENLABS_TIMESTAMPS_GRANULARITY=word
ELEVENLABS_NUM_SPEAKERS=0
ELEVENLABS_KEYTERMS=
BOT_MAX_FILE_MB=50
BOT_REQUEST_TIMEOUT_SECONDS=900
