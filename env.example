# Database
DATABASE_URL=postgresql+asyncpg://pm_user:pm_password@postgres:5432/pm_assistant
POSTGRES_USER=pm_user
POSTGRES_PASSWORD=pm_password
POSTGRES_DB=pm_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App
APP_NAME=PM Assistant API
DEBUG=true
API_PREFIX=/api
PORT=8000

# Active Directory / LDAP
LDAP_SERVER=10.0.20.12
LDAP_BASE_DN=DC=mdigital,DC=local
LDAP_USER_DN=mdigital
LDAP_SERVICE_USER=pm.assistant
LDAP_ADMIN_GROUP=CN=Staff,OU=Groups,DC=mdigital,DC=local
LDAP_SERVICE_PASSWORD=

# Legacy AD fields (for backward compatibility)
AD_SERVER=ldap://ad.example.com
AD_DOMAIN=EXAMPLE
AD_BASE_DN=DC=example,DC=com
AD_USE_NTLM=true

# Session
SESSION_TTL_DAYS=30

# S3 / MinIO (внешний сервер)
S3_ENDPOINT_URL=http://your-minio-server:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=pm-assistant
S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4-turbo-preview

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
