# Database
DATABASE_URL=postgresql+asyncpg://pm_user:pm_password@postgres:5432/pm_assistant
POSTGRES_USER=pm_user
POSTGRES_PASSWORD=pm_password
POSTGRES_DB=pm_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App
APP_NAME=PM Assistant API
DEBUG=true
API_PREFIX=/api
PORT=8000

# Active Directory / LDAP
LDAP_SERVER=10.0.20.12
LDAP_BASE_DN=DC=mdigital,DC=local
LDAP_USER_DN=mdigital
LDAP_SERVICE_USER=pm.assistant
LDAP_ADMIN_GROUP=CN=Staff,OU=Groups,DC=mdigital,DC=local
LDAP_SERVICE_PASSWORD=

# Legacy AD fields (for backward compatibility)
AD_SERVER=ldap://ad.example.com
AD_DOMAIN=EXAMPLE
AD_BASE_DN=DC=example,DC=com
AD_USE_NTLM=true

# Session
SESSION_TTL_DAYS=30

# S3 / MinIO (через прокси nginx или напрямую)
# Для работы через прокси nginx используйте:
# S3_ENDPOINT_URL=https://meet.mdigital.kg/minio
# Для прямого доступа к MinIO:
# S3_ENDPOINT_URL=http://10.0.10.45:9000
S3_ENDPOINT_URL=http://your-minio-server:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=pm-assistant
S3_REGION=us-east-1

# OpenAI (закомментировано - переходим на Gemini)
# OPENAI_API_KEY=sk-your-openai-api-key
# WHISPER_MODEL=whisper-1
# GPT_MODEL=gpt-4-turbo-preview

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# Whisper Transcription (Local)
WHISPER_SERVER_URL=http://10.0.10.3:8000/transcribe
USE_LOCAL_WHISPER=true

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Sentry
SENTRY_DSN=https://5e1b36be0f804e566d8f75fdb50e7897@sentry.mdigital.kg/131
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.005

# Google OAuth
OAUTH_SESSION_SECRET=your-random-secret-key-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://testmeet.mdigital.kg/api/users/auth/google/callback
FRONTEND_URL=https://testmeet.mdigital.kg

